---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'
import type { SanityDocument } from '@sanity/client'
import { sanityClient } from 'sanity:client'

const BLOG_QUERY = `*[
		_type == "blog"
		&& defined(slug.current)
	]|order(publishedAt desc)[0...12]{_id, title, slug, publishedAt}`
const blogs = await sanityClient.fetch<SanityDocument[]>(BLOG_QUERY)

console.log(blogs)

const allBlogs = await getCollection('blog')
---

<Layout title="Nathan Lardizabal | Blog">
	<h1 class="mb-8 text-2xl font-semibold">my blog</h1>
	<p class="text-sm font-light text-slate-300">
		smol things to share - code related or not 🥸
	</p>
	<hr class="my-4 border-slate-700" />
	<section class="flex flex-col gap-4">
		{
			allBlogs.map((blog) => (
				<article>
					<a
						href={`/blog/${blog.slug}`}
						class="w-fit font-light lowercase transition hover:opacity-80"
					>
						{blog.data.title}
					</a>
					<p class="my-1 text-xs text-gray-500 lowercase">
						{blog.data.published.toDateString()}
					</p>
				</article>
			))
		}
		{
			blogs.map((blog) => (
				<article>
					<a href={`/blog/${blog.slug.current}`}>{blog.title}</a>
					<p class="my-1 text-xs text-gray-500 lowercase">{blog.publishedAt}</p>
				</article>
			))
		}
	</section>
</Layout>
