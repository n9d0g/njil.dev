---
import Chip from './Chip.astro'

interface SanityTag {
	name: string
	slug: { current: string }
}

interface Props {
	slug: string
	title: string
	description?: string
	publishedAt: string
	tags?: SanityTag[]
	coverImage?: string
}

const { slug, title, description, publishedAt, tags, coverImage } = Astro.props
const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
})
---

<a href={`/blog/${slug}`} class="group block">
	<article
		class="flex h-full flex-col overflow-hidden rounded border border-gray-700 transition hover:border-gray-400"
	>
		{
			coverImage && (
				<div class="aspect-video w-full overflow-hidden bg-slate-800">
					<img
						src={coverImage}
						alt={title}
						class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
						loading="lazy"
					/>
				</div>
			)
		}
		<div class="flex flex-1 flex-col justify-between p-4">
			<div>
				<h2 class="text-base text-slate-100 transition group-hover:text-white">
					{title}
				</h2>
				<p class="my-1 text-xs font-light text-gray-400">
					{formattedDate}
				</p>
				{
					description && (
						<p class="my-2 line-clamp-2 text-sm font-light text-slate-300">
							{description}
						</p>
					)
				}
			</div>
			{
				tags && tags.length > 0 && (
					<div class="mt-3 flex flex-wrap gap-2">
						{tags.map((tag) => (
							<Chip tag={tag.name} />
						))}
					</div>
				)
			}
		</div>
	</article>
</a>
